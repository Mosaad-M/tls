from crypto.cert import X509Cert, cert_parse

def hex_to_bytes(h: String) -> List[UInt8]:
    var raw = h.as_bytes()
    var n = len(raw) // 2
    var out = List[UInt8](capacity=n)
    for i in range(n):
        var hi = raw[i * 2]
        var lo = raw[i * 2 + 1]
        var h_val: UInt8 = (hi - 48) if hi <= 57 else (hi - 87)
        var l_val: UInt8 = (lo - 48) if lo <= 57 else (lo - 87)
        out.append((h_val << 4) | l_val)
    return out^

def main() raises:
    var gts_r4_hex = ""
    var der = hex_to_bytes(gts_r4_hex)
    try:
        var cert = cert_parse(der)
        print("Parsed OK: ec_curve=", cert.ec_curve, "sig_hash=", cert.sig_hash)
    except e:
        print("FAILED to parse GTS Root R4:", String(e))
